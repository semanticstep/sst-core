@prefix countrycodes: <http://ontology.semanticstep.net/countrycodes#> .
@prefix lci: <http://ontology.semanticstep.net/lci#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

<urn:uuid:aaaaaaaa-1111-1111-1111-111111111111> {
@prefix ns3: <urn:uuid:aaaaaaaa-1111-1111-1111-111111111111#> .

<urn:uuid:aaaaaaaa-1111-1111-1111-111111111111> a owl:Ontology .
ns3:Adam a lci:Person ;
  rdfs:label "Adam Smith" .
ns3:Jane a lci:Person ;
  rdfs:label "Jane Doe" .
ns3:John a lci:Person ;
  rdfs:label "John Doe" .
}

<urn:uuid:bbbbbbbb-2222-2222-2222-222222222222> {
@prefix ns4: <urn:uuid:bbbbbbbb-2222-2222-2222-222222222222#> .

<urn:uuid:bbbbbbbb-2222-2222-2222-222222222222> a owl:Ontology .
ns4:CompanyA a lci:Organization ;
  rdfs:label "Company A" .
ns4:CompanyB a lci:Organization ;
  rdfs:label "Company B" .
_:b0 a lci:Organization ;
  rdfs:label "Stealth Startup" .
}

<urn:uuid:cccccccc-3333-3333-3333-333333333333> {
@prefix ns1: <urn:uuid:cccccccc-3333-3333-3333-333333333333#> .

<urn:uuid:cccccccc-3333-3333-3333-333333333333> a owl:Ontology .
ns1:John ns1:hasFriends ( ns3:Jane ns3:Adam ) ;
  ns1:worksAt ns1:CompanyA ;
  ns1:hasSkill ( "Go" "Python" "RDF" ) .
ns1:hasFriends a rdf:Property .
ns1:hasSkill a rdf:Property .
ns1:worksAt a rdf:Property .
}

<urn:uuid:dddddddd-4444-4444-4444-444444444444> {
@prefix ns2: <urn:uuid:dddddddd-4444-4444-4444-444444444444#> .

<urn:uuid:dddddddd-4444-4444-4444-444444444444> a owl:Ontology .
ns2:Jane lci:partOf countrycodes:de .
ns2:John lci:partOf countrycodes:cn .
}
